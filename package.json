{
  "name": "evermemos-dev-vscode",
  "displayName": "EverMemOS for VS Code",
  "description": "Integrate EverMemOS into VS Code, offering one‑click memory capture, quick recap, project overview, and easy deletion of stored memories directly from the editor.",
  "version": "0.1.0",
  "publisher": "HPC2H2",
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:evermem.configView",
    "onCommand:evermem.addMemory",
    "onCommand:evermem.quickRecap",
    "onCommand:evermem.projectOverview",
    "onCommand:evermem.deleteMemory",
    "onCommand:evermem.openSidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "evermemViewContainer",
          "title": "EverMemOS",
          "icon": "media/evermem.svg"
        }
      ]
    },
    "views": {
      "evermemViewContainer": [
        {
          "id": "evermem.configView",
          "name": "EverMemOS Cloud",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "evermem.addMemory",
        "title": "EverMemOS: Add Memory",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.quickRecap",
        "title": "EverMemOS: Quick Recap",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.projectOverview",
        "title": "EverMemOS: Project Overview",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.deleteMemory",
        "title": "EverMemOS: Delete Memory",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.openSidebar",
        "title": "EverMemOS: Open Sidebar",
        "category": "EverMemOS"
      }
    ],
    "configuration": {
      "title": "EverMemOS",
      "properties": {
        "evermem.apiBaseUrl": {
          "type": "string",
          "default": "https://api.evermind.ai",
          "description": "Base URL of EverMem Cloud API (default: https://api.evermind.ai)"
        },
        "evermem.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "EverMem Cloud API Key（console.evermind.ai 获取）。支持环境变量 `EVERMEM_API_KEY`。示例：` 46b7d3f9-199a-4665-ad1c-6495e1945fd7`"
        },
        "evermem.authToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "(可选) 旧版自托管 Token，若已配置 apiKey 可留空。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run compile-tests && node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
