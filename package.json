{
  "name": "evermemos-dev-vscode",
  "displayName": "EverMemOS for VS Code",
  "description": "Integrate EverMemOS into VS Code, offering one‑click memory capture, quick recap, project overview, and easy deletion of stored memories directly from the editor.",
  "version": "0.0.1",
  "publisher": "HPC2H2",
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "evermem.addMemory",
        "title": "EverMemOS: Add Memory",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.quickRecap",
        "title": "EverMemOS: Quick Recap",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.projectOverview",
        "title": "EverMemOS: Project Overview",
        "category": "EverMemOS"
      },
      {
        "command": "evermem.deleteMemory",
        "title": "EverMemOS: Delete Memory",
        "category": "EverMemOS"
      }
    ],
    "configuration": {
      "title": "EverMemOS",
      "properties": {
        "evermem.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:1995",
          "description": "Base URL of your EverMemOS API, e.g. http://localhost:1995"
        },
        "evermem.authToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional auth token. If set, will be sent as `Authorization: Bearer <token>` with every request."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run compile-tests && node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "uuid": "^13.0.0",
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
